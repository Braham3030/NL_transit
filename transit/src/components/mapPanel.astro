            transform-origin: right;
            transform: translate(-25%, -50%) rotate(-35deg);
            background-color: rgba(0, 0, 0, 1);
            box-shadow: 0 2px 20px rgba(255, 255, 255, 0.8);
        }
        > span:last-of-type {
            top: 0;
