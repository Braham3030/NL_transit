            transition: background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), border-radius 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), box-shadow 1.2s cubic-bezier(0.33, 0.72, 0, 1.18);

        }

        
    }
    > .closeBtn {
            width: 4.5em;
            height: 3em;
            border-radius: 40%;

            position: absolute;
            right: 10%;
            top: 50%;
            transform: translate(0%, -50%);
            opacity: 0;
            z-index: -1;
            pointer-events: none;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: transparent;

            border: none;
