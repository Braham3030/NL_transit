                transform: translate(-75%, -50%) rotate(35deg);
                transform-origin: left;
                background-color: rgba(0, 0, 0, 1);
                box-shadow: 0 2px 20px rgba(255, 255, 255, 0.8);
            }
        }

            > .searchBoxContainer {
                width: 90%;
                margin-top: 4em;
                margin-bottom: 2em;

            > .searchBox {
                width: 100%;
                background-color: transparent;

                > #searchTextBox {
                    transform: translate(5%, -50%);
                    opacity: 1;

                    transition: opacity 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), transform 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), font-size 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), left 0.4s cubic-bezier(0.33, 0.72, 0, 1.18);
                }
                
