            transform-origin: left;
            background-color: rgba(0, 0, 0, 1);
            box-shadow: 0 2px 20px rgba(255, 255, 255, 0.8);
        }
    }

        > .searchBoxContainer {
            width: 90%;
            margin-top: 4em;
            margin-bottom: 0em;

        > .searchBox {
            width: 100%;
            
            background-color: rgba(0, 0, 0, 0.8);
            padding: 0;

            > #Search {
                width: 100%;
            }

            > #searchTextBox {
                transform: translate(9%, -50%);
            }
            
        }
            
        }

    }

    /* Removal of default arrow icon */
    /* https://www.geeksforgeeks.org/css/how-to-remove-the-default-arrow-icon-from-a-dropdown-list/ */
    #Search::-webkit-calendar-picker-indicator {
        display: none !important;
    }

    .searchBoxContainer {
        width: 90%;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        color: rgba(0, 0, 0, 0.8);
        border-radius: 24px;
        margin-bottom: 8em;
        margin-top: 1.6em;
        position: relative;
        
        transition: margin-bottom 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), margin-top 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), border-radius 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), box-shadow 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

    > .searchBox {
        width: 100%;
        border-radius: 24px;
        position: relative;
        background-color: rgba(0, 0, 0, 0.7);


        > #searchTextBox {
            position: absolute;
            top: 50%;
