---
import Navigation from './Navigation.astro';
import RouteTransitList from './RouteTransitList.astro';
import LiveTransitList from './LiveTransitList.astro';
---

<div id="bottomPanel" class="panelBox">
    <span id="panelHandleContainer">
        <span class="panelHandle"></span>
        <span class="panelHandle"></span>
    </span>
    <div class="searchBoxContainer">
    <label for="Search" class="searchBox">
        <input type="text" id="Search" placeholder="" autocorrect="off" list="searchOptions">
        <span id="searchTextBox">Search for <span id="searchText"></span></span>

        <!-- Browser dropdown for search -->
         <!-- https://developer.mozilla.org/en-US/docs/Web/HTML/Reference/Elements/datalist -->
        <datalist id="searchOptions"></datalist>
        
    </label>
    <button class="closeBtn" type="button">
            <span></span>
            <span></span>
        </button>
    </div>
    <div class="containerRouteLive">
        <div class="tabRoute">
            <RouteTransitList />
        </div>
        <div class="tabLive">
            <LiveTransitList />
        </div>
    </div>
    <div class="navigationContainer">
        <Navigation />
    </div>
</div>

<script>
    // @ts-nocheck
    const panel = document.getElementById("bottomPanel");
    const handle = document.getElementById("panelHandleContainer");
    const searchBoxContainer = document.querySelector(".searchBoxContainer");

    let isOpen = false;

    const togglePanel = () => {
        if (!panel) return;
        isOpen = !isOpen;

        if (isOpen) {
            panel.classList.add("open");
        } else {
            panel.classList.remove("open");
        }
    }

    let isDragging = false;
    let startY = 0;
    let startHeight = 0;


    handle?.addEventListener("pointerdown", (e) => {
        if (!panel) return;

        isDragging = true;
        startY = e.clientY;

        // Calculate the current panel height
        startHeight = panel.getBoundingClientRect().height;

        panel.style.transition = "none";

        if (searchBoxContainer)
        searchBoxContainer.style.transition = "none";

        // Browser keeps following the pointer even if it goes outside the element
        handle.setPointerCapture(e.pointerId);
    });

    window.addEventListener("pointermove", (e) => {
        if (!isDragging || !panel) return;

        const deltaY = startY - e.clientY;
        let newHeight = startHeight + deltaY;
        
        const windowHeight = window.innerHeight;
        // Minimum height is 20% of the window
        const minHeight = windowHeight * 0.1;
        // Maximum height is 80% of the window
        const maxHeight = windowHeight * 0.8;

        if (newHeight < minHeight) newHeight = minHeight;
        if (newHeight > maxHeight) newHeight = maxHeight;


        const windowWidth = window.innerWidth;
        let minWidth;
        let maxWidth;

        // if, else statement to determine screen size for width calculations
        if (windowWidth > 1200) {
            minWidth = windowWidth * 0.2;
            maxWidth = windowWidth * 0.24;
        } else if (windowWidth > 800 && windowWidth < 1199) {
            minWidth = windowWidth * 0.3;
            maxWidth = windowWidth * 0.4;
        } else {
            minWidth = windowWidth * 0.9;
            maxWidth = windowWidth * 1;
        }

        // Calculates the height progress as a value between 0 and 1. 0 is the minimum height and 1 the maximum height.
        const progress = (newHeight - minHeight) / (maxHeight - minHeight);

        // Calculates the new width based on the progress.
        let newWidth = minWidth + (maxWidth - minWidth) * progress;
        
        // Calculates the new bottom position based on the progress.
        // 2 - (2 * progress) prevents the bottom from going below 0
        const newBottom = 2 - (2 * progress);

        const newOpacity = 0.2 + (0.4 * progress);
        
        const newBorderRadius = 36 - (20 * progress);

        const newSearchBoxMarginTop = 1.6 + (4 * progress);
        const newSearchBoxMarginBottom = 8 - (2 * progress);


        panel.style.height = `${newHeight}px`;
        panel.style.width = `${newWidth}px`;
        panel.style.bottom = `${newBottom}em`;
        panel.style.opacity = `${newOpacity}`;
        panel.style.borderRadius = `${newBorderRadius}px`;
        
        searchBoxContainer.style.marginTop = `${newSearchBoxMarginTop}em`;
        searchBoxContainer.style.marginBottom = `${newSearchBoxMarginBottom}em`;
    });

    window.addEventListener("pointerup", (e) => {
        if (!isDragging || !panel) return;
        isDragging = false;

        panel.style.transition = ""; 
        if (handle.hasPointerCapture(e.pointerId)) {
            handle.releasePointerCapture(e.pointerId);
        }


        const distanceMoved = Math.abs(startY - e.clientY);

        if (distanceMoved < 5) {
            togglePanel();
            panel.style.height = "";
            panel.style.width = "";
            panel.style.bottom = "";
            panel.style.opacity = "";
            panel.style.borderRadius = "";
            searchBoxContainer.style.marginTop = "";
            searchBoxContainer.style.marginBottom = "";

            // If the panel was toggled, the search box will reset to its default position and styling 
            if (searchBoxContainer) {
                searchBoxContainer.style.transition = "";
                searchBoxContainer.style.marginTop = "";
                searchBoxContainer.style.marginBottom = "";
            }
            return;
        }

        const currentHeight = panel.getBoundingClientRect().height;
        const threshold = window.innerHeight * 0.5;

        if (currentHeight > threshold) {
            isOpen = true;
            panel.classList.add("open");
        } else {
            isOpen = false;
            panel.classList.remove("open");
        }


        // The styling for the open state gets removed. Now the CSS will take over
        panel.style.height = "";
        panel.style.width = "";
        panel.style.bottom = "";
        panel.style.opacity = "";
        panel.style.borderRadius = "";
        searchBoxContainer.style.marginTop = "";
        searchBoxContainer.style.marginBottom = "";

        // The styling for the "open" state will be removed and defaulted to the css state
        if (searchBoxContainer) {
            searchBoxContainer.style.transition = "";
            searchBoxContainer.style.marginTop = "";
            searchBoxContainer.style.marginBottom = "";
        }
    });

    // Random words for search

    const searchWords = ["transit", "stop", "route"];
    const searchText = document.getElementById("searchText");
    let currentWordIndex = 0;


    setInterval(() => {

        searchText.classList.remove('slideIn');
        searchText.classList.add('slideOut');

        setTimeout(() => {
            // currentWordIndex starts at "0" and increases with "1" each interval
            // The "%" here makes the loop complete. It makes sure that the word goes back to the orignal "searchWords.length"
            currentWordIndex = (currentWordIndex + 1) % searchWords.length;
            searchText.textContent = searchWords[currentWordIndex];
            searchText.classList.remove('slideOut');
            searchText.classList.add('slideIn');
    }, 800);
}, 2000);


    // close button 

    const closeBtn = document.querySelector(".closeBtn");
    const searchElement = document.getElementById("Search");

    closeBtn?.addEventListener("click", () => {
        if (!panel) return;

        isOpen = false;
        panel.classList.remove("open");

        // The styling for the "open" state will be removed and defaulted to the styles in css
        panel.style.height = "";
        panel.style.width = "";
        panel.style.opacity = "";

        if (searchElement) {
            // The placeholder will be empty
            searchElement.value = "";
        }
    })


    // Search functionality for data

    if (searchElement) {
        searchElement.addEventListener("keydown", (e) => {
            // Enter key will trigger the search
            if (e.key === "Enter") {
                e.preventDefault();

                // The search value is trimmed to remove extra spaces 
                const searchValue = searchElement.value.trim();

                if (searchValue !== "") {
                    console.log(`Searching for: ${searchValue}`);

                    // Custom event is being used to communicate the search value with the other components.
                    // "search-line" is the name of the event in the other component
                    const searchResults = new CustomEvent("search-line", {
                        detail: { searchName: searchValue }
                    });

                    document.dispatchEvent(searchResults);

                    isOpen = false;
                    panel.classList.remove("open");

                    panel.style.height = "";
                    panel.style.width = "";
                    panel.style.opacity = "";

                    searchElement.blur();
                }
            }
        })
    }


    document.addEventListener("line-check", (e) => {
        const transitLat = e.detail.lat;
        const transitLon = e.detail.lon;

        if (transitLat && transitLon) {
            isOpen = false;
            panel.classList.remove("open");

            panel.style.height = "";
            panel.style.width = "";
            panel.style.opacity = "";
            
        }
    });

    const searchInput = document.getElementById("Search");
    const searchOptions = document.getElementById("searchOptions");

    searchInput?.addEventListener("focus", async () => {
        if (searchOptions.options.length > 0) return;

        const routeResponse = await fetch("/api/Routes");
        const stopsResponse = await fetch("/api/Stops");

        const routeData = await routeResponse.json();
        const stopsData = await stopsResponse.json();

        let dropDownSearch = "";

        routeData.forEach(route => {
            dropDownSearch += `<option value="${route.route_short_name}">${route.route_short_name} - ${route.route_long_name}</option>`;
        })

        stopsData.forEach(stop => {
            dropDownSearch += `<option value="${stop.stop_name}">${stop.stop_name}</option>`;
        })
        

        searchOptions.innerHTML = dropDownSearch;
    });


    // Fun element: mouse following glow effect
    if (panel) {
        panel.addEventListener("mousemove", (e) => {
            // getBoundingClientRect calculates the size of the element and keeps the mouse calculations in the next "const" within the panel
            const rect = panel.getBoundingClientRect();

            // This is the calculation for mouse position in x and in y axis
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            panel.style.setProperty("--mouse-x", `${x}px`);
            panel.style.setProperty("--mouse-y", `${y}px`);
        })
    };

</script>

<style>
    .panelBox {
        z-index: 11111;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        flex-direction: column;
        position: absolute;
        bottom: 2em;
        left: 50%;
        transform: translate(-50%, 150%) scale(0.5);
        width: 90vw;
        height: 12vh;

        background-color: rgba(0, 0, 0, 0.8);
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(8px);
        
        border-radius: 36px;
        overflow: hidden;

        margin: 0;
        padding: 0;

        animation: slideInBottom 1s cubic-bezier(0.33, 0.72, 0, 1.18) 0.5s forwards;

        transition: height 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), bottom 1.2s cubic-bezier(0.33, 0.72, 0, 1.18), border-radius 2s cubic-bezier(0.33, 0.72, 0, 1.18), background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), backdrop-filter 1.2s cubic-bezier(0.33, 0.72, 0, 1.18), left 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), opacity 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

        &::before {
            content: "";
            position: absolute;
            top: 0;
            left: var(--mouse-x);
            top: var(--mouse-y);
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background-color: rgba(138, 138, 138, 0.6);
            filter: blur(100px) brightness(15) contrast(150%) saturate(20%);

            transition: top 0.2s cubic-bezier(0.33, 0.72, 0, 1.18), left 0.2s cubic-bezier(0.33, 0.72, 0, 1.18);
        }

        > #panelHandleContainer {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1em;
            position: fixed;

            width: 20em;
            height: 2em;
            touch-action: none;
