            text-shadow: 0 0px 4px rgba(255, 255, 255, 0.6);
        }
    }

        > #Search {
            width: 100%;
            text-align: left;
            border: 2px solid green;
            height: 100%;
            padding: 0.5em;
            border-radius: inherit;
            font-size: 22px;
            border: none;
