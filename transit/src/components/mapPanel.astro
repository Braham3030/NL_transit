            transition: transform 0.4s cubic-bezier(0.33, 0.72, 0, 1.18), right 0.4s cubic-bezier(0.33, 0.72, 0, 1.18), top 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), opacity 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), height 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), border-radius 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), box-shadow 0.6s cubic-bezier(0.33, 0.72, 0, 1.18) 0.6s;

            > span {
                width: 3em;
                height: 0.5em;
                background-color: rgb(255, 255, 255);
                border-radius: 18px;
                z-index: 1;
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%) rotate(0deg);
                pointer-events: none;

                transition: transform 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
            }
        }
}

        &:has(#Search:not(:placeholder-shown)) #searchTextBox {
            opacity: 0;
            transform: translate(100%, -50%);
            font-size: 16px;

        }

        &:has(#Search:focus) .panelBox {
            border-radius: 20px 20px 0 0;
            bottom: 0;
            width: 100vw;
            height: 80vh;

            background-color: rgba(0, 0, 0, 0.8);
            box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.8), 0 2px 20px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);

            > #panelHandleContainer {
                height: 3em;

             > span:first-of-type {
                top: 0;
                left: 50%;
                width: 3em;
                transform-origin: right;
                transform: translate(-25%, -50%) rotate(-35deg);
                background-color: rgba(0, 0, 0, 1);
                box-shadow: 0 2px 20px rgba(255, 255, 255, 0.8);
            }
            > span:last-of-type {
