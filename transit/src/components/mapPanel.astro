            position: absolute;
            top: 0;
            left: 50%;
            transform: translate(-50%, 0%) rotate(0deg);
            z-index: 1000;

            cursor: grab;
            touch-action: none;

            transition: width 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), box-shadow 0.2s cubic-bezier(0.33, 0.72, 0, 1.18), background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), left 0.2s cubic-bezier(0.33, 0.72, 0, 1.18), transform 0.6s cubic-bezier(0.33, 0.72, 0, 1.18);

        &:active {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.8);
            cursor: grabbing;
        }
    }
    }
    }

    .panelBox.open {
        border-radius: 20px 20px 0 0;
        bottom: 0;
        width: 100vw;
        height: 80vh;

        background-color: rgba(0, 0, 0, 0.8);
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.8), 0 2px 20px rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(15px);

        > #panelHandleContainer {
            height: 3em;

        > span:first-of-type {
            top: 0;
            left: 50%;
