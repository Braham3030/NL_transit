                    transform: translate(-50%, -50%) rotate(45deg);
                }
                > span:last-child {
                    transform: translate(-50%, -50%) rotate(-45deg);
                }
            }
        }

        &:has(#Search:not(:placeholder-shown)) #searchTextBox {
            opacity: 0;
            transform: translate(20%, -50%);
            left: 20%;
            }
        }
        
        .slideIn {
            animation: SlideInText 0.8s ease-in-out forwards;
        }

        .slideOut {
            animation: SlideOutText 0.8s ease-in-out forwards;
        }

        .containerRouteLive {
            flex: 1;
            width: fit-content;
            margin: 0 auto;
        }

        .navigationContainer {
            width: 100%;
            padding-bottom: 5em;
        }

        .tabLive, .tabRoute {
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            visibility: hidden;

            transition: opacity 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), top 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), visibility 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
        }
    
    

    @keyframes slideInBottom {
        0% {
            transform: translate(-50%, 100%) scale(0.5);
            opacity: 0;
        }
        100% {
            transform: translate(-50%, 0) scale(1);
            opacity: 1;
        }
    }

    @keyframes SlideInText {
        0% {
            opacity: 0;
            transform: translateY(-100%) scale(0.8);
        }
        100% {
            opacity: 1;
            transform: translateY(0%) scale(1);
        }
    }

    @keyframes SlideOutText {
        0% {
            opacity: 1;
            transform: translateY(0%) scale(1);
        }
        100% {
            opacity: 0;
            transform: translateY(100%) scale(0.8);
        }
    }

    /* Desktop layout */

    @media (min-width: 1200px) {
        .panelBox {
            bottom: .5em;
            left: 14%;
            transform: translate(-50%, 150%) scale(0.5);
            width: 24vw;

            transition: left 0.4s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), height 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), bottom 1.2s cubic-bezier(0.33, 0.72, 0, 1.18), border-radius 2s cubic-bezier(0.33, 0.72, 0, 1.18), background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), backdrop-filter 1.2s cubic-bezier(0.33, 0.72, 0, 1.18), opacity 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
        }

        .panelBox.open {
            left: 14%;
            width: 24vw;
        }

        &:has(#Search:focus) .panelBox {
            width: 24vw;
        }
    }
    
    @media (min-width: 800px) and (max-width: 1199px) {
        .panelBox {
            bottom: 1em;
            left: 18%;
            transform: translate(-50%, 150%) scale(0.5);
            width: 35vw;

            transition: left 0.4s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), height 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), bottom 1.2s cubic-bezier(0.33, 0.72, 0, 1.18), border-radius 2s cubic-bezier(0.33, 0.72, 0, 1.18), background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), backdrop-filter 1.2s cubic-bezier(0.33, 0.72, 0, 1.18), opacity 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
        }

        .panelBox.open {
            left: 18%;
            width: 30vw;
        }

        &:has(#Search:focus) .panelBox {
            width: 30vw;
        }
    }
</style>