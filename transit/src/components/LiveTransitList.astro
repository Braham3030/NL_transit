<div class="liveTransitListContainer">
    <h3 class="liveTransitListTitle">Live transit times</h3>
    <ul class="liveTransitList">
        <li>Loading data...</li>
        <!-- <li>Test time 1</li>
        <li>Test time 2</li>
        <li>Test time 3</li>
        <li>Test time 4</li>
        <li>Test time 5</li>
        <li>Test time 6</li>
        <li>Test time 7</li>
        <li>Test time 8</li>
        <li>Test time 9</li> -->
    </ul>
</div>

<script>
    // @ts-nocheck
    // Live transit times based on API data and user location
    const timeItems = document.querySelector("li")

    document.addEventListener("liveLocationUpdate", (e) => {
        const transit = e.detail.transitInfo;

        document.querySelector(".liveTransitListTitle").innerHTML = `Live transit times for ${transit.shortName}`;

        const list = document.querySelector(".liveTransitList");

        // Empty the list before adding new items

        list.innerHTML = "";

        if (!transit ||transit.length === 0) {
            list.innerHTML = "<li>No live transit times available for line ${transit.shortName}</li>";
            return;
        }

        transit.forEach((transit, index) => {
            
            const li = document.createElement("li");

            li.innerHTML = `
            Bus ${index + 1}
            ${transit.longName}`;
            // list.appendChild gets the list item and puts it in the list
            list.appendChild(li);
        });
    })

    


    
</script>


<style>
    h3 {
        color: white;
    }
    div {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        margin-bottom: 20em;

        > ul {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            flex-direction: column;
            gap: 1em;
            list-style-type: none;
            padding: 0;
            margin: 0;
            background-color: transparent;

            height: 8em;
            overflow-y: scroll;
            overflow-x: visible;
            scroll-snap-type: mandatory;
            scrollbar-color: transparent transparent;

            > li {
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 18px;
                height: 6em;
                width: 10em;

                color: white;
                background-color: rgba(255, 255, 255, 0.26);
                box-shadow: 0 2px 5px rgba(255, 255, 255, 0.3);
                backdrop-filter: blur(2px);
            }
        }
    }
</style>