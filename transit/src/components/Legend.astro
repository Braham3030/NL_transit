<div class="Legend">
    <details>
    <summary>Legend</summary>
    <ul>
        <li><div class="stopsLegend"></div><strong>Stops:</strong> Stops for transit</li>
        <li>
            <div class="busIcon">
                <svg width="80%" height="80%" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
 <path d="M8.5 19V21.2C8.5 21.48 8.5 21.62 8.4455 21.727C8.39757 21.8211 8.32108 21.8976 8.227 21.9455C8.12004 22 7.98003 22 7.7 22H5.8C5.51997 22 5.37996 22 5.273 21.9455C5.17892 21.8976 5.10243 21.8211 5.0545 21.727C5 21.62 5 21.48 5 21.2V19M19 19V21.2C19 21.48 19 21.62 18.9455 21.727C18.8976 21.8211 18.8211 21.8976 18.727 21.9455C18.62 22 18.48 22 18.2 22H16.3C16.02 22 15.88 22 15.773 21.9455C15.6789 21.8976 15.6024 21.8211 15.5545 21.727C15.5 21.62 15.5 21.48 15.5 21.2V19M3 12H21M3 5.5H21M6.5 15.5H8M16 15.5H17.5M7.8 19H16.2C17.8802 19 18.7202 19 19.362 18.673C19.9265 18.3854 20.3854 17.9265 20.673 17.362C21 16.7202 21 15.8802 21 14.2V6.8C21 5.11984 21 4.27976 20.673 3.63803C20.3854 3.07354 19.9265 2.6146 19.362 2.32698C18.7202 2 17.8802 2 16.2 2H7.8C6.11984 2 5.27976 2 4.63803 2.32698C4.07354 2.6146 3.6146 3.07354 3.32698 3.63803C3 4.27976 3 5.11984 3 6.8V14.2C3 15.8802 3 16.7202 3.32698 17.362C3.6146 17.9265 4.07354 18.3854 4.63803 18.673C5.27976 19 6.11984 19 7.8 19Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
 </svg>
            </div>
            <strong>Bus:</strong> Bus route.
        </li>
        <!-- <li><strong>Subway:</strong> A subway route.</li>
        <li><strong>Tram:</strong> A tram route.</li> -->
    </ul>
    </details>
</div>

<style>
    .Legend {
        position: absolute;
        display: flex;
        align-items: flex-end;
        justify-content: flex-end;
        bottom: 9.5em;
        right: 1.3em;
        transform: translate(-20%, -50%);
        z-index: 9999;
        width: auto;
        height: auto;
        background-color: transparent;
        padding: 0;
        border-radius: 0.5em;

        transition: transform 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), bottom 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), right 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), margin-top 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), opacity 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

        > details {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            /* padding: 0.5em; */
            border-radius: 16px;
            width: 7em;
            height: 3.5em;
            padding: 0;
            overflow: hidden;

            color: white;
            background-color: rgba(0, 0, 0, 0.7);
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(8px);
            position: absolute;
            bottom: 0;
            right: 0;
            transform: translate(0, 0);
            transform-origin: bottom right;

            transition: width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), height 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), bottom 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), right 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), padding 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

            animation: Shrink 0.8s cubic-bezier(0.33, 0.72, 0, 1.18) forwards;

            > summary {
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 24px;
                width: 100%;
                height: 100%;
                font-weight: bold;
                cursor: pointer;
                list-style-type: none;
                padding-top: 0.2em;
                padding-bottom: 0.2em;
                border-radius: 0.5em;

                transition: all 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
            }

        > ul {
            display: flex;
            flex-direction: column;
            gap: 0em;
            list-style-type: none;
            padding: 0;
            margin: 0;
            margin-top: 0em;

            /* cubic-bezier(0.33, 0.72, 0, 1.18) forwards */
            transition: all 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

            > li {
                display: flex;
                align-items: center;
                justify-content: flex-start;
                flex-direction: row;
                gap: 0.5em;

                font-size: 14px;

                transition: all 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

                > div {
                    margin-right: 0.5em;
                }

                > .stopsLegend {
                    width: 2em;
                    height: 2em;
                    border-radius: 50%;
                    border: 2px solid white;
                    background-color: #3388ff;
                }

                > .busIcon {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    width: 2em;
                    height: 2em;
                    border-radius: 50%;
                    border: 2px solid white;
                }
            }
        }
    }

    > details[open] {
        width: 22em;
        height: 13em;
        bottom: 0;
        right: 0;
        padding: 0.8em;
        transform: translate(0, 0);
        align-items: flex-start;
        justify-content: flex-start;

        background-color: rgba(0, 0, 0, 0.8);
        /* height: auto; */
        transition: background-color 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.6s cubic-bezier(0.33, 0.72, 0, 1.18), height 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), bottom 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), right 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), padding 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
        animation: enLarge 0.8s cubic-bezier(0.33, 0.72, 0, 1.18) forwards;

        > summary {
            font-size: 36px;
            justify-content: flex-start;

            transition: all 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
        }

        > ul {
            gap: 1em;
            margin-top: 0em;

            > li {
                font-size: 24px;
                text-wrap: nowrap;

                transition: all 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

                > div {
                    animation: iconGrow 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);
                }

                > .stopsLegend {
                    animation-delay: 0.2s;
                }
                > .busIcon {
                    animation-delay: 0.4s;
                }
            }
        }
    }
}


@keyframes enLarge {
    from {
        width: 7em;
    }
    to {
        width: 22em;
    }
}

@keyframes Shrink {
    from {
        width: 22em;
    }
    to {
        width: 7em;
    }
}

@keyframes iconGrow {
    0% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.2);
    }
    100% {
        transform: scale(1);
    }
}
</style>