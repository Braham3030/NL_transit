---
// @ts-nocheck
import Time from './Time.astro';
import Route from './Route.astro';
---

<nav>
    <ul>
        <li class="nav-item active">
            <Time />
        </li>
        <li class="nav-item">
            <Route />
        </li>
    </ul>
</nav>

<div id="time-result"></div>
<div id="routes-result"></div>

<script>
    // @ts-nocheck
    const navItems = document.querySelectorAll(".nav-item");
    const ul = document.querySelector("nav > ul");

    const moveBackground = (activeItem) => {
        if (!activeItem || !ul) return;

        const left = activeItem.offsetLeft;
        const width = activeItem.offsetWidth;

        ul.style.setProperty("--bg-left", `${left}px`);
        ul.style.setProperty("--bg-width", `${width}px`);
    }

    const startActive = document.querySelector(".nav-item.active");
    moveBackground(startActive);

    setTimeout(() => {
        ul?.classList.add("glowBox");
    }, 800);

    navItems.forEach(item => {
        item.addEventListener("click", () => {
            ul?.classList.remove("glowBox");

            navItems.forEach(i => i.classList.remove("active"));
            item.classList.add("active");

            moveBackground(item);

            setTimeout(() => {
                ul?.classList.add("glowBox");
            }, 800);
        });
    });

    let isDragging = false;
    let startX = 0;
    let startLeft = 0;

    ul?.addEventListener("pointerdown", (e) => {
        isDragging = true;
        startX = e.clientX;

        const currentLeft = ul.style.getPropertyValue("--bg-left");
        startLeft = parseFloat(currentLeft) || startActive.offsetLeft;

        ul.classList.add("dragging");
        ul.classList.remove("glowBox");

        // Browser keeps following the pointer even if it goes outside the element
        ul.setPointerCapture(e.pointerId);
    });

    ul?.addEventListener("pointermove", (e) => {
        if (!isDragging) return;

        const deltaX = e.clientX - startX;
        let newLeft = startLeft + deltaX;

        const firstLeft = navItems[0].offsetLeft;
        const lastLeft = navItems[navItems.length - 1].offsetLeft;
        if (newLeft < firstLeft) newLeft = firstLeft;
        if (newLeft > lastLeft) newLeft = lastLeft;


        ul.style.setProperty("--bg-left", `${newLeft}px`);
    });

    ul?.addEventListener("pointerup", (e) => {
        if (!isDragging) return;
        isDragging = false;
        ul.classList.remove("dragging");
        ul.releasePointerCapture(e.pointerId);

        // The background will snap to the closest item when released
        const currentLeft = parseFloat(ul.style.getPropertyValue("--bg-left")) || 0;
        // closestItem here is the navItem that is closest to the current background
        let closestItem = navItems[0];
        let minDiff = Infinity;
        
        navItems.forEach(item => {
            const diff = Math.abs(currentLeft - item.offsetLeft);
            if (diff < minDiff) {
                minDiff = diff;
                closestItem = item;
            }
        });

        navItems.forEach(i => i.classList.remove("active"));
        closestItem.classList.add("active");
        moveBackground(closestItem);

        setTimeout(() => {
            ul?.classList.add("glowBox");
        }, 800);
    });

    // document.querySelector("#time")?.addEventListener("click", () => {
    //     fetch("/api/time")
    //         .then(response => response.json())
    //         .then(data => {
    //             document.querySelector("#time-result").innerHTML = JSON.stringify(data);
    //         });
    // });
</script>

<style>
    nav {
        /* background-color: rgba(0, 0, 0, 0.5); */
        border-radius: 12px;
        width: 90%;
        margin: 0 auto;

        > ul {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: row;
            gap: 2em;

            margin: 0;
            padding: 0;
            position: relative;
            z-index: 1;
            /* Prevents browser from horizontal scroll */
            touch-action: pan-y;
            cursor: grab;

            transition: left 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

            &::before {
                content: "";
                position: absolute;
                top: 0;
                left: var(--bg-left, 0);
                width: var(--bg-width, 0);
                height: 100%;
                background-color: rgba(29, 29, 29, 0.3);
                border-radius: 32px;
                z-index: -1;
                /* transition: left 0.3s ease, width 0.3s ease; */
                transition: left 0.8s cubic-bezier(0.33, 0.72, 0, 1.18), width 0.8s cubic-bezier(0.33, 0.72, 0, 1.18);

            }

            &.glowBox::before {
                animation: navBackgroundGlow 0.8s ease-in-out forwards;
            }

            &.dragging {
                cursor: grabbing;
            }

            &.dragging::before {
                transition: none !important;
            }

            > li {
                list-style-type: none;
                padding: 1em 2em;
                font-size: 20px;
                border-radius: 8px;
                user-select: none;
                transform-origin: center;
                text-shadow: none;

                transition: transform 1.2s cubic-bezier(0.33, 0.72, 0, 1.18);

                &.active {
                    color: black;
                    transform: scale(1.5);
                    text-shadow: 0 20px 10px rgba(0, 0, 0, 0.5);
                }
                

                > button {
                    border: none;
                    background: none;
                    color: inherit;
                    font-size: inherit;
                }
            }
        }
    }


    @keyframes navBackgroundGlow {
        0% {
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
        }
        100% {
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.8);
        }
    }
</style>